---
import { useTranslations, getLocaleFromUrl, locales, localeMeta, pathForLocale, defaultLocale } from '../i18n';
import { docUrl } from '../lib/docs';

const lang = getLocaleFromUrl(Astro.url);
const { t } = useTranslations(lang);

const links = [
  { href: '/#features', label: t('nav.features') },
  { href: '/#boot', label: t('nav.howItWorks') },
  { href: '/downloads', label: t('nav.downloads') },
  { href: docUrl(lang), label: t('nav.docs') },
  { href: 'https://github.com/garybowers/bootimus', label: t('nav.github'), external: true },
];

const langItems = locales.map((code) => ({
  code,
  ...localeMeta[code],
  href: pathForLocale(Astro.url.pathname, code),
  active: code === lang,
}));
---
<nav class="nav">
  <div class="container nav-inner">
    <a href={lang === defaultLocale ? '/' : `/${lang}/`} class="brand" aria-label="Bootimus home">
      <span class="brand-mark">[</span><span class="brand-name">bootimus</span><span class="brand-mark">]</span>
    </a>
    <ul class="nav-links">
      {links.map((l) => (
        <li class="nav-li">
          <a href={l.href} target={l.external ? '_blank' : undefined} rel={l.external ? 'noopener' : undefined}>
            {l.label}
          </a>
        </li>
      ))}
      <li class="nav-actions">
        <details class="lang-pop">
          <summary class="lang-btn" aria-label={t('nav.languageLabel')} title={t('nav.languageLabel')}>
            <svg width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="10" cy="10" r="7.5"/>
              <path d="M2.5 10h15M10 2.5c2.5 2.5 2.5 12.5 0 15M10 2.5c-2.5 2.5-2.5 12.5 0 15"/>
            </svg>
            <span class="lang-code">{localeMeta[lang].flag}</span>
            <svg class="caret" width="10" height="10" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
              <path d="M2.5 4l2.5 2.5 2.5-2.5"/>
            </svg>
          </summary>
          <ul class="lang-menu" role="menu">
            {langItems.map((li) => (
              <li role="none">
                {li.ready ? (
                  <a href={li.href} class:list={["lang-item", li.active && "lang-item-active"]} role="menuitem">
                    <span class="lang-item-flag">{li.flag}</span>
                    <span class="lang-item-native">{li.native}</span>
                    {li.active && <span class="lang-item-tick" aria-hidden="true">✓</span>}
                  </a>
                ) : (
                  <span class="lang-item lang-item-disabled" aria-disabled="true" role="menuitem">
                    <span class="lang-item-flag">{li.flag}</span>
                    <span class="lang-item-native">{li.native}</span>
                    <span class="lang-item-soon">{t('nav.comingSoon')}</span>
                  </span>
                )}
              </li>
            ))}
          </ul>
        </details>

        <button class="theme-tog" id="theme-toggle" type="button" aria-label={t('nav.toggleTheme')} title={t('nav.toggleTheme')}>
          <svg class="ico ico-sun" width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
            <circle cx="10" cy="10" r="3.2"/>
            <path d="M10 2v2M10 16v2M2 10h2M16 10h2M4.4 4.4l1.4 1.4M14.2 14.2l1.4 1.4M4.4 15.6l1.4-1.4M14.2 5.8l1.4-1.4"/>
          </svg>
          <svg class="ico ico-moon" width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16.5 12.5A7 7 0 1 1 7.5 3.5a5.5 5.5 0 0 0 9 9z"/>
          </svg>
        </button>
      </li>
    </ul>
  </div>
</nav>

<script is:inline>
  (function () {
    const btn = document.getElementById('theme-toggle');
    if (btn) {
      btn.addEventListener('click', () => {
        const cur = document.documentElement.getAttribute('data-theme') || 'dark';
        const next = cur === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        try { localStorage.setItem('bootimus-theme', next); } catch (_) {}
      });
    }
    document.addEventListener('click', (e) => {
      const open = document.querySelector('details.lang-pop[open]');
      if (open && !open.contains(e.target)) open.removeAttribute('open');
    });
  })();
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 200;
    backdrop-filter: blur(12px) saturate(140%);
    -webkit-backdrop-filter: blur(12px) saturate(140%);
    background: var(--nav-bg);
    border-bottom: 1px solid var(--border);
    transition: background 220ms ease, border-color 220ms ease;
  }
  .nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }
  .brand {
    font-weight: 700;
    font-size: 1rem;
    letter-spacing: -0.02em;
    color: var(--text);
    display: inline-flex;
    gap: 1px;
    transition: color 160ms ease;
  }
  .brand:hover { color: var(--amber); }
  .brand-mark { color: var(--amber); font-weight: 500; }
  .brand-name { color: inherit; }

  .nav-links {
    list-style: none;
    display: flex;
    gap: 1.5rem;
    margin: 0;
    padding: 0;
    align-items: center;
  }
  .nav-links a {
    font-size: 0.85rem;
    color: var(--text);
    opacity: 0.78;
    letter-spacing: 0.01em;
    transition: color 160ms ease, opacity 160ms ease;
  }
  .nav-links a:hover { color: var(--amber); opacity: 1; }

  .nav-actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-left: 0.5rem;
  }

  .lang-pop {
    position: relative;
  }
  .lang-pop[open] .caret { transform: rotate(180deg); }
  .lang-btn {
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    height: 32px;
    padding: 0 0.55rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-dim);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 4px;
    cursor: pointer;
    user-select: none;
    transition: all 160ms ease;
  }
  .lang-btn::-webkit-details-marker { display: none; }
  .lang-btn::marker { display: none; content: ''; }
  .lang-btn:hover {
    color: var(--amber);
    border-color: var(--border-bright);
    background: var(--bg-elev);
  }
  .lang-code {
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--text);
  }
  .caret { transition: transform 160ms ease; }

  .lang-menu {
    position: absolute;
    top: calc(100% + 6px);
    right: 0;
    min-width: 200px;
    background: var(--bg-elev);
    border: 1px solid var(--border-bright);
    border-radius: 6px;
    list-style: none;
    margin: 0;
    padding: 0.35rem;
    box-shadow: 0 12px 30px -8px rgba(0,0,0,0.35);
    z-index: 100;
  }
  .lang-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.45rem 0.6rem;
    font-size: 0.82rem;
    color: var(--text);
    border-radius: 4px;
    text-decoration: none;
    transition: background 120ms ease;
  }
  .lang-item-flag {
    font-weight: 600;
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    color: var(--text-dim);
    background: var(--bg-term);
    border: 1px solid var(--border);
    border-radius: 3px;
    padding: 0.1rem 0.35rem;
    min-width: 28px;
    text-align: center;
  }
  .lang-item-native { flex: 1; }
  .lang-item-tick { color: var(--amber); }
  .lang-item:hover:not(.lang-item-disabled) { background: var(--bg-term); color: var(--amber); }
  .lang-item-active { color: var(--amber); }
  .lang-item-disabled {
    color: var(--text-faint);
    cursor: not-allowed;
  }
  .lang-item-soon {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-faint);
    border: 1px dashed var(--border);
    border-radius: 100px;
    padding: 0.05rem 0.45rem;
  }

  .theme-tog {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text-dim);
    cursor: pointer;
    padding: 0;
    transition: all 160ms ease;
  }
  .theme-tog:hover {
    color: var(--amber);
    border-color: var(--border-bright);
    background: var(--bg-elev);
  }
  .ico { width: 16px; height: 16px; }
  .ico-sun { display: block; }
  .ico-moon { display: none; }
  :global([data-theme="light"]) .ico-sun { display: none; }
  :global([data-theme="light"]) .ico-moon { display: block; }

  @media (max-width: 720px) {
    .nav-links { gap: 0.9rem; }
    .nav-li:nth-child(2) { display: none; }
    .lang-item-native { font-size: 0.78rem; }
  }
  @media (max-width: 520px) {
    .nav-li:nth-child(1) { display: none; }
  }
</style>
